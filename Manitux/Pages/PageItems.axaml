<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:collections="clr-namespace:Avalonia.Collections;assembly=Avalonia.Base"
             xmlns:iri="https://irihi.tech/shared"
             xmlns:u="https://irihi.tech/ursa"
             xmlns:async="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
             xmlns:vm="clr-namespace:Manitux.ViewModels"
			 xmlns:loaders="clr-namespace:Manitux.Services.ImageLoaders"
             mc:Ignorable="d" d:DesignWidth="800"
             d:DesignHeight="450"
             x:DataType="vm:PageItemsViewModel"
             x:Class="Manitux.Pages.PageItems">
	<UserControl.Styles>
		<Style Selector="Border.MovieCard">
			<Setter Property="Transitions">
				<Transitions>
					<TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.3" Easing="CubicEaseOut"/>
					<BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.3" />
				</Transitions>
			</Setter>
		</Style>

		<Style Selector="Border.MovieCard:pointerover">
			<Setter Property="RenderTransform" Value="scale(1.05)"/>
			<Setter Property="BoxShadow" Value="0 10 20 0 #80000000"/>
			<Setter Property="ZIndex" Value="1"/>
		</Style>

		<Style Selector="Border.MovieCard Image">
			<Setter Property="Transitions">
				<Transitions>
					<DoubleTransition Property="Opacity" Duration="0:0:0.3"/>
				</Transitions>
			</Setter>
		</Style>

		<Style Selector="Border.MovieCard:pointerover Image">
			<Setter Property="Opacity" Value="0.8"/>
		</Style>
	</UserControl.Styles>


	<Grid RowDefinitions="*, Auto">
		<!--<TextBlock Text="İçerikler" FontSize="24" Foreground="White" Margin="20,20,0,10" FontWeight="Bold"/>-->
        <ScrollViewer Name="MainScrollViewer" Grid.Row="0"  HorizontalScrollBarVisibility="Disabled"
              VerticalScrollBarVisibility="Auto">
        <ItemsControl ItemsSource="{Binding PageItems}">
            
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Width="150" Margin="10">

						<Border Classes="MovieCard"
                                CornerRadius="8"
                                ClipToBounds="True"
                                Background="Black"
                                BoxShadow="0 4 10 0 #40000000"
								Width="150"
								Height="220">
							<Button Padding="0"
                                    HorizontalAlignment="Stretch"
									VerticalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    VerticalContentAlignment="Stretch"
									Command="{Binding $parent[ItemsControl].((vm:PageItemsViewModel)DataContext).OnActivate}"
									CommandParameter="{Binding}">
								<Grid>
									<!-- image -->
									<async:AdvancedImage
													Width="150"
													Height="220"
													Source="{Binding Poster}"
													Loader="{x:Static loaders:CustomWebImageLoader.Instance}"
													Stretch="Uniform"/>
									<!--<Image async:ImageLoader.Source="{Binding Poster}"
										   Stretch="UniformToFill"
										   HorizontalAlignment="Stretch"
										   VerticalAlignment="Stretch"/>-->

									<!-- year -->
									<Border Background="#CC1E1E1E"
											CornerRadius="4"
											Padding="6,3"
											Margin="6"
											HorizontalAlignment="Left"
											VerticalAlignment="Top">
										<TextBlock Text="{Binding Year}"
												   Foreground="White"
												   FontSize="11"
												   FontWeight="SemiBold"/>
									</Border>

									<!-- rating -->
									<Border Background="#CC1E1E1E"
											CornerRadius="4"
											Padding="6,3"
											Margin="6"
											HorizontalAlignment="Right"
											VerticalAlignment="Top">
										<StackPanel Orientation="Horizontal" Spacing="2">
											<TextBlock Text="⭐"
													   FontSize="10"
													   Foreground="White"
													   VerticalAlignment="Center"/>
											<TextBlock Text="{Binding Rating}"
													   Foreground="White"
													   FontSize="11"
													   FontWeight="Bold"
													   VerticalAlignment="Center"/>
										</StackPanel>
									</Border>
								</Grid>
							</Button>
                        </Border>
						

                       <TextBlock Text="{Binding Title}" 
                                   Margin="0,8,0,0"
                                   FontSize="14"
                                   FontWeight="Medium"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap" />
                        
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
            
        </ItemsControl>
    </ScrollViewer>
		<Grid Grid.Row="1"
			  Margin="0,12,0,0"
			  HorizontalAlignment="Center"
			  IsVisible="{Binding IsPaginationVisible}"
			  ColumnDefinitions="40,40,72,40">
			<Button Grid.Column="0"
					Width="36"
					Height="36"
					Padding="0"
					Command="{Binding GoFirstPageCommand}">
				<TextBlock HorizontalAlignment="Center"
						   VerticalAlignment="Center"
						   FontSize="14"
						   FontWeight="SemiBold"
						   Text="1"/>
			</Button>
			<Button Grid.Column="1"
					Width="36"
					Height="36"
					Padding="0"
					Command="{Binding GoPreviousPageCommand}">
				<TextBlock HorizontalAlignment="Center"
						   VerticalAlignment="Center"
						   FontSize="18"
						   Text="&lt;"/>
			</Button>
			<Border Grid.Column="2"
					MinWidth="64"
					Height="36"
					Margin="6,0"
					HorizontalAlignment="Center"
					VerticalAlignment="Center"
					Background="#CC1E1E1E"
					BorderBrush="#66FFFFFF"
					BorderThickness="1"
					CornerRadius="6">
				<TextBlock HorizontalAlignment="Center"
						   VerticalAlignment="Center"
						   FontWeight="SemiBold"
						   Foreground="White"
						   Text="{Binding CurrentPage}"/>
			</Border>
			<Button Grid.Column="3"
					Width="36"
					Height="36"
					Padding="0"
					Command="{Binding GoNextPageCommand}">
				<TextBlock HorizontalAlignment="Center"
						   VerticalAlignment="Center"
						   FontSize="18"
						   Text="&gt;"/>
			</Button>
		</Grid>
	</Grid>
</UserControl>
