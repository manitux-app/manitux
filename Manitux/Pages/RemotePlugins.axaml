<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:u="https://irihi.tech/ursa"
             xmlns:vm="clr-namespace:Manitux.ViewModels"
             xmlns:plugins="clr-namespace:Manitux.Core.Services.Plugins;assembly=Manitux.Core"
             mc:Ignorable="d"
             d:DesignWidth="1000"
             d:DesignHeight="700"
             x:DataType="vm:RemotePluginsViewModel"
             x:Class="Manitux.Pages.RemotePlugins">
    <u:LoadingContainer IsLoading="{Binding IsLoading}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
        <Grid RowDefinitions="Auto,Auto,*" RowSpacing="14" Margin="16">
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                <TextBox Grid.Column="0"
                         Watermark="GitHub repo URL, raw repo.json, plugins.json, plugin URL, or short code"
                         Text="{Binding RepositoryInput, Mode=TwoWay}" />
                <u:IconButton Grid.Column="1"
                              Classes="Primary"
                              Command="{Binding AddRepositoryCommand}"
                              Content="Add"
                              Icon="{StaticResource SemiIconPlus}" />
                <u:IconButton Grid.Column="2"
                              Classes="Tertiary"
                              Command="{Binding RefreshCommand}"
                              Icon="{StaticResource SemiIconRefresh}"
                              ToolTip.Tip="Refresh" />
            </Grid>

            <u:Banner Grid.Row="1"
                      ShowIcon="True"
                      Type="{Binding StatusType}"
                      IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                      Content="{Binding StatusMessage}" />

            <Grid Grid.Row="2" ColumnDefinitions="280,*,360" ColumnSpacing="14">
                <Grid Grid.Column="0" RowDefinitions="Auto,*" RowSpacing="10">
                    <TextBlock Text="Repositories" Classes="Header H3" />
                    <ScrollViewer Grid.Row="1">
                        <ItemsControl ItemsSource="{Binding Repositories}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="plugins:ManagedRemoteRepository">
                                    <Border Margin="0,0,0,8"
                                            Padding="10"
                                            Theme="{DynamicResource CardBorder}">
                                        <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding Description}"
                                                       Opacity="0.75"
                                                       TextWrapping="Wrap"
                                                       MaxLines="2" />
                                            <u:IconButton Grid.Row="2"
                                                          HorizontalAlignment="Left"
                                                          Classes="Tertiary"
                                                          Command="{Binding $parent[UserControl].((vm:RemotePluginsViewModel)DataContext).LoadRepositoryCommand}"
                                                          CommandParameter="{Binding}"
                                                          Content="Open"
                                                          Icon="{StaticResource SemiIconFolderOpen}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <Grid Grid.Column="1" RowDefinitions="Auto,*" RowSpacing="10">
                    <TextBlock Text="Available Plugins" Classes="Header H3" />
                    <ScrollViewer Grid.Row="1">
                        <ItemsControl ItemsSource="{Binding AvailablePlugins}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="plugins:RemotePluginManifest">
                                    <Border Margin="0,0,0,8"
                                            Padding="10"
                                            Theme="{DynamicResource CardBorder}">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding Description}" Opacity="0.75" TextWrapping="Wrap" MaxLines="2" />
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{Binding InternalName}" Opacity="0.65" />
                                                    <TextBlock Text="{Binding Version, StringFormat='v{0}'}" Opacity="0.65" />
                                                    <TextBlock Text="{Binding Language}" Opacity="0.65" />
                                                </StackPanel>
                                            </StackPanel>
                                            <u:IconButton Grid.Column="1"
                                                          Classes="Primary"
                                                          Command="{Binding $parent[UserControl].((vm:RemotePluginsViewModel)DataContext).InstallCommand}"
                                                          CommandParameter="{Binding}"
                                                          Icon="{StaticResource SemiIconDownload}"
                                                          ToolTip.Tip="Install" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <Grid Grid.Column="2" RowDefinitions="Auto,*" RowSpacing="10">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBlock Text="Installed Plugins" Classes="Header H3" />
                        <u:IconButton Grid.Column="1"
                                      Classes="Tertiary"
                                      Command="{Binding UpdateAllCommand}"
                                      Icon="{StaticResource SemiIconSync}"
                                      ToolTip.Tip="Update all" />
                    </Grid>
                    <ScrollViewer Grid.Row="1">
                        <ItemsControl ItemsSource="{Binding InstalledPlugins}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="plugins:ManagedRemotePlugin">
                                    <Border Margin="0,0,0,8"
                                            Padding="10"
                                            Theme="{DynamicResource CardBorder}">
                                        <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding FilePath}"
                                                       Opacity="0.65"
                                                       TextWrapping="Wrap"
                                                       MaxLines="2" />
                                            <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                                <TextBlock VerticalAlignment="Center"
                                                           Text="{Binding Version, StringFormat='v{0}'}"
                                                           Opacity="0.7" />
                                                <u:IconButton Grid.Column="1"
                                                              Classes="Tertiary"
                                                              Command="{Binding $parent[UserControl].((vm:RemotePluginsViewModel)DataContext).UpdateCommand}"
                                                              CommandParameter="{Binding}"
                                                              Icon="{StaticResource SemiIconRefresh}"
                                                              ToolTip.Tip="Update" />
                                                <u:IconButton Grid.Column="2"
                                                              Classes="Tertiary"
                                                              Command="{Binding $parent[UserControl].((vm:RemotePluginsViewModel)DataContext).RemoveCommand}"
                                                              CommandParameter="{Binding}"
                                                              Icon="{StaticResource SemiIconDelete}"
                                                              ToolTip.Tip="Remove" />
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>
    </u:LoadingContainer>
</UserControl>
