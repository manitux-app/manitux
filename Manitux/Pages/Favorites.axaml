<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:u="https://irihi.tech/ursa"
             xmlns:async="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
             xmlns:vm="clr-namespace:Manitux.ViewModels"
             xmlns:pages="clr-namespace:Manitux.Pages"
             xmlns:loaders="clr-namespace:Manitux.Services.ImageLoaders"
             mc:Ignorable="d" d:DesignWidth="800"
             d:DesignHeight="450"
             x:DataType="vm:FavoritesViewModel"
             x:Class="Manitux.Pages.Favorites">
    <UserControl.Styles>
        <Style Selector="Border.MovieCard">
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                    <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.3" />
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Border.MovieCard:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.05)"/>
            <Setter Property="BoxShadow" Value="0 10 20 0 #80000000"/>
            <Setter Property="ZIndex" Value="1"/>
        </Style>

        <Style Selector="Border.MovieCard Image">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.3"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Border.MovieCard:pointerover Image">
            <Setter Property="Opacity" Value="0.8"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">
        <pages:PluginTopBar Grid.Row="0" DataContext="{Binding TopBar}"/>

        <u:LoadingContainer Grid.Row="1" IsLoading="{Binding IsLoading}" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
            <Grid>
                <TextBlock Text="{Binding L.NoFavoritesFound}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="18"
                           Opacity="0.7"
                           IsVisible="{Binding !IsVisible}"/>

                <ScrollViewer Name="MainScrollViewer"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto"
                              IsVisible="{Binding IsVisible}">
                    <ItemsControl ItemsSource="{Binding PageItems}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Width="150" Margin="10">
                                    <Border Classes="MovieCard"
                                            CornerRadius="8"
                                            ClipToBounds="True"
                                            Background="Black"
                                            BoxShadow="0 4 10 0 #40000000"
                                            Width="150"
                                            Height="220">
                                        <Button Padding="0"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Stretch"
                                                HorizontalContentAlignment="Stretch"
                                                VerticalContentAlignment="Stretch"
                                                Command="{Binding $parent[ItemsControl].((vm:FavoritesViewModel)DataContext).OnActivate}"
                                                CommandParameter="{Binding}">
                                            <Grid>
                                                <async:AdvancedImage
                                                    Width="150"
                                                    Height="220"
                                                    Source="{Binding Poster}"
                                                    Loader="{x:Static loaders:CustomWebImageLoader.Instance}"
                                                    Stretch="Uniform"/>

                                                <Border Background="#CC1E1E1E"
                                                        CornerRadius="4"
                                                        Padding="6,3"
                                                        Margin="6"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Top">
                                                    <TextBlock Text="{Binding Year}"
                                                               Foreground="White"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"/>
                                                </Border>

                                                <Border Background="#CC1E1E1E"
                                                        CornerRadius="4"
                                                        Padding="6,3"
                                                        Margin="6"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Top">
                                                    <StackPanel Orientation="Horizontal" Spacing="2">
                                                        <TextBlock Text="⭐"
                                                                   FontSize="10"
                                                                   Foreground="White"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Rating}"
                                                                   Foreground="White"
                                                                   FontSize="11"
                                                                   FontWeight="Bold"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </Button>
                                    </Border>

                                    <TextBlock Text="{Binding Title}"
                                               Margin="0,8,0,0"
                                               FontSize="14"
                                               FontWeight="Medium"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </u:LoadingContainer>
    </Grid>
</UserControl>
